# =============================================================================
# sistema-inventario-backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit .env. Only .env.example is tracked in git.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Node environment: development | test | production
NODE_ENV=development

# HTTP port the server listens on (default: 3000)
PORT=3000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string (REQUIRED)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inventario_dev

# ---------------------------------------------------------------------------
# Authentication — JWT
# ---------------------------------------------------------------------------

# Secret for signing access tokens. REQUIRED. Minimum 32 characters.
JWT_ACCESS_SECRET=change-me-min-32-chars-access-secret-here

# Secret for signing refresh tokens. REQUIRED. Minimum 32 characters.
# Must be different from JWT_ACCESS_SECRET.
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret-here

# Access token TTL in ms-style duration (default: 15m)
JWT_ACCESS_TTL=15m

# Refresh token TTL in ms-style duration (default: 7d)
JWT_REFRESH_TTL=7d

# ---------------------------------------------------------------------------
# Password hashing
# ---------------------------------------------------------------------------

# bcrypt work factor (default: 10). Range: 8–14.
# 10 ≈ 100ms on typical dev hardware; increase to 12 for production.
BCRYPT_COST=10

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Allowed frontend origin for CORS (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------

# Maximum requests per window per IP (default: 100)
RATE_LIMIT_MAX=100

# Rate-limit window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Pino log level: fatal | error | warn | info | debug | trace (default: info)
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database seed (initial admin user)
# ---------------------------------------------------------------------------

# Admin account created by `npm run db:seed`. Change before first deploy.
SEED_ADMIN_EMAIL=admin@highmeds.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FULLNAME=Administrador
