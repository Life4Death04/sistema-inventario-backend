// =============================================================================
// Prisma Schema — sistema-inventario-backend (HighMeds Pharmacy)
// =============================================================================
// Decisions:
//   - ID strategy: cuid() — URL-safe, k-sorted, no row-count leak
//   - Product.unit/unitContent/brand closed by Engram #281
//   - All FK onDelete actions are explicit (no driver defaults)
//   - RefreshToken implements JWT DB allowlist (design §6)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Shared lifecycle status for entities that support soft-delete.
/// ACTIVE   — entity is operational.
/// DISABLED — entity exists but is blocked from new operations (no new movements, requests, etc.).
/// DELETED  — entity is soft-deleted; hidden from default list views and treated as NOT_FOUND.
/// Introduced by backend-hardening Slice B / PR2 (additive; `active` column preserved for rollback).
enum EntityStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum AdjustmentDirection {
  INCREASE
  DECREASE
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
}

enum ReplenishmentStatus {
  PENDING
  SENT
  RECEIVED
  CANCELLED
}

/// Unit of measure for the product content (not the outer packaging).
/// Examples: 100 ML (syrup), 500 G (powder), 30 UNIT (tablets).
/// The outer packaging (BOLSA, CAJA, BLISTER) lives in Product.presentation.
enum ProductUnit {
  MG
  G
  KG
  ML
  L
  UNIT
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String       @id @default(cuid())
  fullName  String
  email     String       @unique
  password  String // bcrypt hash — NEVER returned in API responses
  role      UserRole     @default(OPERATOR)
  active    Boolean      @default(true)
  status    EntityStatus @default(ACTIVE) // additive — active preserved; swap in Slice B commit 2
  phone     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  movements                InventoryMovement[]
  replenishmentRequests    ReplenishmentRequest[]
  resolvedAlerts           Alert[]                @relation("AlertResolver")
  refreshTokens            RefreshToken[]
  receivedRequests         ReplenishmentRequest[] @relation("ReplenishmentReceiver")
  cancelledRequests        ReplenishmentRequest[] @relation("ReplenishmentCanceller")

  @@index([email])
  @@index([active])
  @@index([role])
  @@index([status])
}

/// JWT refresh token DB allowlist.
/// Each row represents one live refresh token family.
/// revoked=true means the token has been used/expired/logged-out.
/// Reuse detection: if jti is not found OR revoked=true, revoke the entire
/// family for this user (onDelete: Cascade handles user deletion cleanup).
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean   @default(false)
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  status      EntityStatus @default(ACTIVE) // no prior `active` column; soft-delete introduced in Slice B
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  products Product[]

  @@index([status])
}

/// ✅ Schema CLOSED — Engram #281 (topic: sdd/backend-foundations/product-fields-decision).
/// Added fields: unit (ProductUnit enum), unitContent (Decimal 10,3), brand (VarChar 120 optional).
/// Excluded: barcode, internalRef, model, weightKg, warrantyMonths, allowDecimalStock,
///           contentUnit, currency, commission/vendor fields, and separate Brand/UnidadMedida tables.
model Product {
  id               String       @id @default(cuid())
  code             String       @unique
  name             String
  activeIngredient String?
  description      String?
  presentation     String? // outer packaging (BOLSA, CAJA, BLISTER) — free text, NOT the unit
  brand            String?      @db.VarChar(120)
  unit             ProductUnit // unit of measure for the content (required)
  unitContent      Decimal      @db.Decimal(10, 3) // content magnitude, e.g. 100.000 ML
  categoryId       String
  category         Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  stock            Int          @default(0)
  minStock         Int          @default(0)
  price            Decimal?     @db.Decimal(12, 2)
  active           Boolean      @default(true)
  status           EntityStatus @default(ACTIVE) // additive — active preserved; swap in Slice B commit 2
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  suppliers          ProductSupplier[]
  movements          InventoryMovement[]
  alerts             Alert[]
  replenishmentItems ReplenishmentRequestItem[]

  @@index([code])
  @@index([categoryId])
  @@index([active])
  @@index([stock]) // supports "stock <= minStock" low-stock queries
  @@index([brand]) // brand search / filter
  @@index([status])
}

model Supplier {
  id        String       @id @default(cuid())
  name      String
  rif       String?      @unique // Postgres allows multiple NULLs on UNIQUE columns
  whatsapp  String?
  address   String?
  active    Boolean      @default(true)
  status    EntityStatus @default(ACTIVE) // additive — active preserved; swap in Slice B commit 2
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  products              ProductSupplier[]
  replenishmentRequests ReplenishmentRequest[]

  @@index([active])
  @@index([status])
}

/// Explicit M:N join between Product and Supplier.
/// Explicit (not implicit) because the relationship carries referencePrice.
model ProductSupplier {
  id             String   @id @default(cuid())
  productId      String
  supplierId     String
  referencePrice Decimal? @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([productId, supplierId])
  @@index([productId])
  @@index([supplierId])
}

/// Immutable audit log for all stock changes.
/// quantity is ALWAYS positive. Direction is determined by type + adjustmentDirection.
/// No updatedAt — this model is append-only (service layer enforces immutability).
model InventoryMovement {
  id                  String               @id @default(cuid())
  productId           String
  userId              String
  type                MovementType
  adjustmentDirection AdjustmentDirection? // required when type = ADJUSTMENT (service enforces)
  reason              String
  quantity            Int // ALWAYS > 0 (validated by service layer)
  resultingStock      Int // post-operation stock snapshot
  createdAt           DateTime             @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict) // preserve history
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict) // traceability

  @@index([productId, createdAt])
  @@index([userId])
  @@index([type])
}

model Alert {
  id               String    @id @default(cuid())
  productId        String
  type             AlertType
  message          String
  resolved         Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedByUserId String?
  createdAt        DateTime  @default(now())

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  resolvedBy User?   @relation("AlertResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([resolved])
  @@index([productId, resolved]) // "is there an open alert for this product?"
  @@index([resolved, createdAt])
}

model ReplenishmentRequest {
  id                  String              @id @default(cuid())
  supplierId          String
  requestedByUserId   String
  status              ReplenishmentStatus @default(PENDING)
  requestedAt         DateTime            @default(now())
  sentAt              DateTime?
  receivedAt          DateTime?
  cancelledAt         DateTime?
  receivedByUserId    String?
  cancelledByUserId   String?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  supplier          Supplier                   @relation(fields: [supplierId], references: [id], onDelete: Restrict) // preserve order history
  requestedByUser   User                       @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  receivedByUser    User?                      @relation("ReplenishmentReceiver", fields: [receivedByUserId], references: [id], onDelete: Restrict)
  cancelledByUser   User?                      @relation("ReplenishmentCanceller", fields: [cancelledByUserId], references: [id], onDelete: Restrict)
  items             ReplenishmentRequestItem[]

  @@index([supplierId])
  @@index([status])
  @@index([requestedAt])
  @@index([supplierId, status])
  @@index([receivedByUserId])
  @@index([cancelledByUserId])
}

model ReplenishmentRequestItem {
  id                     String  @id @default(cuid())
  replenishmentRequestId String
  productId              String
  requestedQuantity      Int
  receivedQuantity       Int?
  unitPrice              Decimal? @db.Decimal(12, 2)

  request ReplenishmentRequest @relation(fields: [replenishmentRequestId], references: [id], onDelete: Cascade)
  product Product              @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([replenishmentRequestId, productId])
  @@index([replenishmentRequestId])
  @@index([productId])
}
